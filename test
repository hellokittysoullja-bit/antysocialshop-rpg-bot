import time
from typing import Dict

class UltimateIdempotentCache:
    __slots__ = ('_data', '_ttl', '_lock', '_last_cleanup')
    def __init__(self, ttl_seconds: int = 3600):
        self._ttl = ttl_seconds
        self._data: Dict[int, float] = {}
        self._lock = asyncio.Lock()
        self._last_cleanup: float = 0.0

    async def check_and_set(self, key: int) -> bool:
        async with self._lock:
            now = time.monotonic()
            if now - self._last_cleanup > 60:
                expired = [k for k, ts in self._data.items() if now - ts > self._ttl]
                for k in expired:
                    self._data.pop(k, None)
                self._last_cleanup = now
            if key in self._data:
                return True
            self._data[key] = now
            return False

    async def discard(self, key: int) -> None:
        async with self._lock:
            self._data.pop(key, None) IDEMPOTENT_CACHE = UltimateIdempotentCache(ttl_seconds=3600)
