async def handle_webhook(request):
    # 1. Быстрый парсинг
    try:
        data = await request.json()
    except Exception:
        return web.Response(text="Bad Request", status=400)

    if not isinstance(data, dict) or "update_id" not in data:
        return web.Response(text="Bad Request", status=400)

    update_id = data["update_id"]

    # 2. Идемпотентность через твой UltimateIdempotentCache
    already_processed = await IDEMPOTENT_CACHE.check_and_set(update_id)
    if already_processed:
        return web.Response(text="OK")

    # 3. Контекст должен быть готов
    ctx = tg_app.bot_data.get("ctx")
    if not ctx:
        await IDEMPOTENT_CACHE.discard(update_id)
        return web.Response(text="Service Unavailable", status=503)

    # 4. Синхронная обработка с таймаутом (не фон!)
    try:
        update = Update.de_json(data, tg_app.bot)
        await asyncio.wait_for(
            tg_app.process_update(update),
            timeout=5.0
        )
        return web.Response(text="OK")
    except asyncio.TimeoutError:
        logger.error("⏰ Таймаут update_id=%d", update_id)
        await IDEMPOTENT_CACHE.discard(update_id)
        return web.Response(text="Service Unavailable", status=503)
    except Exception:
        logger.exception("💥 Ошибка update_id=%d", update_id)
        await IDEMPOTENT_CACHE.discard(update_id)
        return web.Response(text="Internal Server Error", status=500)


